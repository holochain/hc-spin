{
  "name": "@holochain/hc-spin",
  "version": "0.700.0-rc.1",
  "holochainVersion": "0.7.0-rc.3",
  "description": "CLI to run Holochain apps during development.",
  "author": "matthme",
  "homepage": "https://developer.holochain.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holochain/hc-spin.git"
  },
  "keywords": [
    "holochain",
    "developer",
    "tools",
    "tooling",
    "developer-tools",
    "cli"
  ],
  "license": "MIT",
  "main": "out/main/index.js",
  "bin": {
    "hc-spin": "./dist/cli.js"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "yarn run typecheck:node && yarn run typecheck:web",
    "start": "node dist/cli.js",
    "build": "rimraf dist && yarn run typecheck && electron-vite build && mv ./out ./dist && cp ./cli/cli.js ./dist/cli.js && node ./scripts/replace-electron-version.js",
    "prepublishOnly": "npm run format:check && npm run lint:check && npm run build"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@holochain/client": "^0.21.0-rc.1",
    "@holochain/hc-spin-rust-utils": "0.700.0-rc.1",
    "@msgpack/msgpack": "^3.1.3",
    "bufferutil": "4.1.0",
    "commander": "15.0.0",
    "electron": "^42.5.0",
    "electron-context-menu": "4.1.2",
    "get-port": "7.2.0",
    "js-sha512": "^0.9.0",
    "nanoid": "5.1.15",
    "split": "1.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^24.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.8.4",
    "rimraf": "6.1.3",
    "typescript": "^6.0.3",
    "utf-8-validate": "^6.0.6",
    "vite": "^7.3.5"
  },
  "packageManager": "yarn@1.22.19"
}
